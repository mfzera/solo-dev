generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("ideas")
  tags        String    @default("[]")
  estimate    String?
  flagged     Boolean   @default(false)
  blocked     Boolean   @default(false)
  checked     Boolean   @default(false)
  progress    Int?
  sortOrder   Int       @default(0)
  assignee    String?
  startDate   DateTime?
  dueDate     DateTime?
  archivedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model QuickCapture {
  id               String  @id @default(cuid())
  text             String
  promotedToTaskId String?
  createdAt        DateTime @default(now())
}

model WeeklyPlanEntry {
  id        String   @id @default(cuid())
  dayOfWeek Int
  weekStart DateTime
  taskTitle String
  done      Boolean  @default(false)
  taskId    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  taskId     String?
  action     String
  occurredAt DateTime @default(now())
}

model TagConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model VideoSession {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("idea")
  script    String?
  ideas     String?
  tags      String   @default("[]")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
