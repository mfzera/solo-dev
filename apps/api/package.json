{
  "name": "@solo-dev/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "npx tsup src/index.ts --format esm --outDir dist --no-splitting",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "setup-admin": "tsx --env-file=.env scripts/setup-admin.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "@paralleldrive/cuid2": "^2.2.2",
    "@scalar/hono-api-reference": "^0.9.48",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.11",
    "postgres": "^3.4.5",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "drizzle-kit": "^0.31.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
